#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

HUGO_BIN=""
if [[ -x "$ROOT_DIR/tools/hugo-0.154.2/hugo" ]]; then
  HUGO_BIN="$ROOT_DIR/tools/hugo-0.154.2/hugo"
elif [[ -x "$ROOT_DIR/tools/hugo/hugo" ]]; then
  HUGO_BIN="$ROOT_DIR/tools/hugo/hugo"
else
  HUGO_BIN="hugo"
fi

if [[ -x "$ROOT_DIR/tools/go/bin/go" ]]; then
  export PATH="$ROOT_DIR/tools/go/bin:$PATH"
  export GOPATH="${GOPATH:-$ROOT_DIR/.gopath}"
fi

exec "$HUGO_BIN" "$@"
